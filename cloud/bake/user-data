#cloud-config
# SibillaOS bake-phase configuration. Runs exactly once inside the
# build VM, then reseals cloud-init: the deployer's own user-data
# applies at the real first boot. No user is created here.
#
# The bake logic lives in a real bash script dropped via write_files
# and invoked explicitly with bash: string-form runcmd items run under
# /bin/sh (dash), where ERR traps and other bashisms fail silently.
users: []
write_files:
  - path: /usr/local/sbin/sibilla-bake
    permissions: "0755"
    content: |
      #!/usr/bin/env bash
      # Output goes to the serial console so the builder can follow
      # the progress and detect the outcome markers.
      set -euo pipefail
      exec > /dev/console 2>&1
      trap 'echo SIBILLA_BAKE_FAILED' ERR
      echo "bake: starting"
      mkdir -p /mnt/seed
      mount -o ro /dev/disk/by-label/CIDATA /mnt/seed \
        || mount -o ro /dev/disk/by-label/cidata /mnt/seed
      export DEBIAN_FRONTEND=noninteractive
      # skip Translation files (pure description localization): a
      # mid-sync mirror serving a stale one fails the whole update;
      # the file persists so the deployed image is immune too
      printf 'Acquire::Languages "none";\nAcquire::Retries "3";\n' \
        > /etc/apt/apt.conf.d/90sibilla-apt-robustness
      # mirrors are sometimes caught mid-sync ("File has unexpected
      # size"): retry with a pause instead of failing the whole bake
      for i in 1 2 3 4 5; do
        if apt-get -o Acquire::Retries=3 update; then
          break
        fi
        if [ "$i" = 5 ]; then
          echo "apt-get update kept failing"
          exit 1
        fi
        echo "apt-get update failed (mirror mid-sync?), retrying in 60s"
        sleep 60
      done
      dpkg -i /mnt/seed/debs/*.deb \
        || apt-get -o Acquire::Retries=3 -f install -y
      # inference engine, PINNED version (same pin as the ISO build);
      # retried because a mid-download TCP reset once corrupted the
      # tarball and failed a whole bake
      ollama_ok=0
      for _ in 1 2 3; do
        if curl -fsSL https://ollama.com/install.sh | OLLAMA_VERSION=0.32.1 sh; then
          ollama_ok=1
          break
        fi
        echo "ollama install failed, retrying in 15s"
        sleep 15
      done
      [ "$ollama_ok" -eq 1 ] || { echo "ollama install failed after 3 attempts"; exit 1; }
      if [ -f /mnt/seed/ci-model ]; then
        # -D: /etc/llmd does not exist yet at bake time; on the ISO
        # path the installer late-commands create it, here the whole
        # llmd setup is deferred to the first boot
        install -D -m644 /mnt/seed/ci-model /etc/llmd/model
      fi
      install -D -m644 /dev/null /etc/llmd/appliance
      systemctl enable llmd-firstboot.service
      umount /mnt/seed
      # reseal: wipe cloud-init state and the machine identity so
      # every deployment starts as a fresh instance
      cloud-init clean --logs --machine-id
      rm -f /usr/local/sbin/sibilla-bake
      echo "SIBILLA_BAKE_OK"
runcmd:
  - [bash, /usr/local/sbin/sibilla-bake]
power_state:
  mode: poweroff
  timeout: 60
  condition: true
