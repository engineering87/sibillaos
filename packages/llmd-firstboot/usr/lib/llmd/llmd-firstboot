#!/usr/bin/env bash
# llmd-firstboot: at first boot, generate the API key, download or resume the
# model, configure the gateway and start the services. Idempotent.
set -euo pipefail

STATE=/var/lib/llmd/firstboot.done
[[ -e "$STATE" ]] && exit 0

# systemd oneshot units have no HOME; the ollama CLI panics without it
export HOME="${HOME:-/root}"

engine=$(cat /etc/llmd/engine 2>/dev/null || echo ollama)
model=$(cat /etc/llmd/model 2>/dev/null || true)
mkdir -p /var/lib/llmd/models /etc/llmd

# 1. API key: stored for the admin and exported to Caddy via gateway.env
if [[ ! -s /etc/llmd/apikey ]]; then
  (umask 077; head -c32 /dev/urandom | base64 | tr -d '=+/' | cut -c1-40 > /etc/llmd/apikey)
fi
(umask 077; printf 'LLMD_API_KEY=%s\n' "$(cat /etc/llmd/apikey)" > /etc/llmd/gateway.env)

# 2. Model (retry with resume; both engines resume partial downloads)
if [[ -n "$model" ]]; then
  case "$engine" in
    ollama)
      systemctl start ollama.service
      for _ in 1 2 3; do
        if ollama pull "$model"; then break; fi
        sleep 30
      done
      ;;
    vllm)
      echo "LLMD_MODEL=$model" > /etc/llmd/vllm.env
      # the HF download happens at the first container start (persistent cache)
      ;;
  esac
fi

# 3. Gateway: upstream depends on the engine
case "$engine" in
  vllm)   upstream="127.0.0.1:8000" ;;
  *)      upstream="127.0.0.1:11434" ;;
esac
sed "s/{UPSTREAM}/$upstream/" /etc/llmd/Caddyfile > /etc/caddy/Caddyfile

# 4. Services. The vllm unit is generated by Quadlet: it cannot be
# enabled with systemctl (boot activation comes from its [Install]
# section), so it is only started.
systemctl daemon-reload
case "$engine" in
  vllm) systemctl start vllm.service ;;
  *)    systemctl enable --now ollama.service ;;
esac
# caddy is already running with the stock config from the Ubuntu package,
# so enable --now would be a no-op: an explicit restart loads our gateway
# config and the API key environment
systemctl enable caddy.service
systemctl restart caddy.service

touch "$STATE"
echo "SibillaOS is ready: OpenAI-compatible API on :8080 (key in /etc/llmd/apikey)"
