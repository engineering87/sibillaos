#!/usr/bin/env bash
# llmd-firstboot: at first boot, generate the API key, download or resume the
# model, configure the gateway and start the services. Idempotent.
set -euo pipefail

STATE=/var/lib/llmd/firstboot.done
[[ -e "$STATE" ]] && exit 0

# systemd oneshot units have no HOME; the ollama CLI panics without it
export HOME="${HOME:-/root}"

mkdir -p /var/lib/llmd/models /etc/llmd

# Cloud images skip the installer: detect the engine and pick a model
# here, at the real first boot, where the deployed hardware (and its
# GPU, if any) is visible. No-ops on ISO installs, where the files
# were already written by the autoinstall late-commands.
if [[ ! -s /etc/llmd/engine && -x /usr/lib/llmd/llmd-hw-detect ]]; then
  /usr/lib/llmd/llmd-hw-detect --write /etc/llmd/engine || true
fi
if [[ ! -s /etc/llmd/model && -x /usr/lib/llmd/llmd-model-select ]]; then
  /usr/lib/llmd/llmd-model-select --auto \
    --catalog /usr/share/llmd/models.json --out /etc/llmd/model || true
fi

engine=$(cat /etc/llmd/engine 2>/dev/null || echo ollama)
model=$(cat /etc/llmd/model 2>/dev/null || true)

# 1. API keys: the default key is generated here; extra keys are
# managed later with sibilla key. llmd-keys-render turns them all
# into the gateway.env consumed by the Caddy matcher.
if [[ ! -s /etc/llmd/apikey ]]; then
  (umask 077; head -c32 /dev/urandom | base64 | tr -d '=+/' | cut -c1-40 > /etc/llmd/apikey)
fi
mkdir -p /etc/llmd/apikeys.d
chmod 700 /etc/llmd/apikeys.d
/usr/lib/llmd/llmd-keys-render

# 2. Model (retry with resume; both engines resume partial downloads)
if [[ -n "$model" ]]; then
  case "$engine" in
    ollama)
      # The models dir ships root-owned in the deb, but ollama runs as
      # its own user and must own it: this was the root cause of the
      # first-boot crash loop ("mkdir .../blobs: permission denied").
      # The ollama user only exists after its installer ran, so the
      # ownership can only be fixed here, not in the package.
      mkdir -p /var/lib/llmd/models/ollama
      if id ollama >/dev/null 2>&1; then
        chown -R ollama:ollama /var/lib/llmd/models/ollama
      fi
      # restart, not start: the unit is likely rate-limited from the
      # crash loop and a plain start would be a no-op
      systemctl restart ollama.service
      # wait for the API to accept connections before pulling
      up=0
      for _ in $(seq 1 30); do
        if curl -fsS -o /dev/null http://127.0.0.1:11434/ 2>/dev/null; then
          up=1
          break
        fi
        sleep 3
      done
      # self-heal: early-boot crash loops can trip the systemd start
      # rate limit and leave the unit down; a fresh restart recovers it
      if [[ "$up" -eq 0 ]]; then
        systemctl restart ollama.service || true
        for _ in $(seq 1 20); do
          if curl -fsS -o /dev/null http://127.0.0.1:11434/ 2>/dev/null; then
            break
          fi
          sleep 3
        done
      fi
      for _ in 1 2 3; do
        if ollama pull "$model"; then break; fi
        sleep 30
      done
      ;;
    vllm)
      echo "LLMD_MODEL=$model" > /etc/llmd/vllm.env
      # the HF download happens at the first container start (persistent cache)
      ;;
  esac
fi

# 3. Gateway: render the Caddy config; the mode lives in gateway.conf
# (plain http by default, switch with sibilla-tls)
[[ -r /etc/llmd/gateway.conf ]] || printf 'MODE=http\n' > /etc/llmd/gateway.conf
/usr/lib/llmd/llmd-gateway-render

# 4. Services. The vllm unit is generated by Quadlet: it cannot be
# enabled with systemctl (boot activation comes from its [Install]
# section), so it is only started.
systemctl daemon-reload
case "$engine" in
  vllm) systemctl start vllm.service ;;
  *)    systemctl enable --now ollama.service ;;
esac
# access log directory: the caddy user only exists after its package
# is installed, so the ownership cannot be fixed in a deb
mkdir -p /var/log/caddy
if id caddy >/dev/null 2>&1; then
  chown caddy:caddy /var/log/caddy
fi
# caddy is already running with the stock config from the Ubuntu package,
# so enable --now would be a no-op: an explicit restart loads our gateway
# config and the API key environment
systemctl enable caddy.service
systemctl restart caddy.service

# 5. Firewall: default-closed, only SSH and the gateway port open.
# Open WebUI's port 3000 stays closed until the admin opens it
# deliberately (sibilla webui enable prints the command).
if command -v ufw >/dev/null 2>&1; then
  ufw allow OpenSSH >/dev/null 2>&1 || ufw allow 22/tcp >/dev/null
  ufw allow 8080/tcp >/dev/null
  ufw --force enable
  echo "firewall enabled: only SSH and the gateway port are open"
fi

touch "$STATE"
echo "SibillaOS is ready: OpenAI-compatible API on :8080 (key in /etc/llmd/apikey)"
