#!/usr/bin/env bash
# llmd-firstboot: at first boot, generate the API key, download or resume the
# model, configure the gateway and start the services. Idempotent.
set -euo pipefail

STATE=/var/lib/llmd/firstboot.done
[[ -e "$STATE" ]] && exit 0

# systemd oneshot units have no HOME; the ollama CLI panics without it
export HOME="${HOME:-/root}"

mkdir -p /var/lib/llmd/models /etc/llmd

# Air-gapped payload: a volume labeled SIBILLA-AIRGAP carries model
# files that will go through the same digest gate as sibilla model
# import, and optionally a declared profile. Mounted read-only now
# because a profile on the stick must seed the model choice below;
# the files import further down, once the engine is up.
AIRGAP_MNT=""
if [[ -e /dev/disk/by-label/SIBILLA-AIRGAP ]]; then
  AIRGAP_MNT=$(mktemp -d)
  if mount -o ro /dev/disk/by-label/SIBILLA-AIRGAP "$AIRGAP_MNT" 2>/dev/null; then
    echo "air-gapped payload detected"
    if [[ -s "$AIRGAP_MNT/profile" && ! -s /etc/llmd/profile ]]; then
      cp "$AIRGAP_MNT/profile" /etc/llmd/profile
      echo "profile taken from the payload"
    fi
  else
    rmdir "$AIRGAP_MNT" 2>/dev/null || true
    AIRGAP_MNT=""
  fi
fi

# A declared profile (written by cloud-init, a fleet tool or the
# air-gapped payload) wins over auto-selection: seed the model before
# the choice happens, so the declared one is what gets downloaded.
if [[ -s /etc/llmd/profile && ! -s /etc/llmd/model ]]; then
  profile_model=$(sed -n 's/^MODEL=//p' /etc/llmd/profile | head -1)
  if [[ -n "$profile_model" ]]; then
    echo "$profile_model" > /etc/llmd/model
    echo "model taken from the declared profile: $profile_model"
  fi
fi

# Cloud images skip the installer: detect the engine and pick a model
# here, at the real first boot, where the deployed hardware (and its
# GPU, if any) is visible. No-ops on ISO installs, where the files
# were already written by the autoinstall late-commands.
if [[ ! -s /etc/llmd/engine && -x /usr/lib/llmd/llmd-hw-detect ]]; then
  /usr/lib/llmd/llmd-hw-detect --write /etc/llmd/engine || true
fi
if [[ ! -s /etc/llmd/model && -x /usr/lib/llmd/llmd-model-select ]]; then
  /usr/lib/llmd/llmd-model-select --auto \
    --catalog /usr/share/llmd/models.json --out /etc/llmd/model || true
fi

engine=$(cat /etc/llmd/engine 2>/dev/null || echo ollama)
model=$(cat /etc/llmd/model 2>/dev/null || true)

# 1. API keys: the default key is generated here; extra keys are
# managed later with sibilla key. llmd-keys-render turns them all
# into the gateway.env consumed by the Caddy matcher.
if [[ ! -s /etc/llmd/apikey ]]; then
  (umask 077; head -c32 /dev/urandom | base64 | tr -d '=+/' | cut -c1-40 > /etc/llmd/apikey)
fi
mkdir -p /etc/llmd/apikeys.d
chmod 700 /etc/llmd/apikeys.d
/usr/lib/llmd/llmd-keys-render

# 2. Model (retry with resume; both engines resume partial downloads)
if [[ -n "$model" ]]; then
  case "$engine" in
    ollama)
      # The models dir ships root-owned in the deb, but ollama runs as
      # its own user and must own it: this was the root cause of the
      # first-boot crash loop ("mkdir .../blobs: permission denied").
      # The ollama user only exists after its installer ran, so the
      # ownership can only be fixed here, not in the package.
      mkdir -p /var/lib/llmd/models/ollama
      if id ollama >/dev/null 2>&1; then
        chown -R ollama:ollama /var/lib/llmd/models/ollama
      fi
      # restart, not start: the unit is likely rate-limited from the
      # crash loop and a plain start would be a no-op
      systemctl restart ollama.service
      # wait for the API to accept connections before pulling
      up=0
      for _ in $(seq 1 30); do
        if curl -fsS -o /dev/null http://127.0.0.1:11434/ 2>/dev/null; then
          up=1
          break
        fi
        sleep 3
      done
      # self-heal: early-boot crash loops can trip the systemd start
      # rate limit and leave the unit down; a fresh restart recovers it
      if [[ "$up" -eq 0 ]]; then
        systemctl restart ollama.service || true
        for _ in $(seq 1 20); do
          if curl -fsS -o /dev/null http://127.0.0.1:11434/ 2>/dev/null; then
            break
          fi
          sleep 3
        done
      fi
      # payload files import first, through the same digest gate as
      # sibilla model import: a file the catalog does not know stays
      # out, and a warning is not a failed boot
      if [[ -n "$AIRGAP_MNT" ]]; then
        for f in "$AIRGAP_MNT"/models/*.gguf; do
          [[ -e "$f" ]] || continue
          sibilla-model import "$f" \
            || echo "WARNING: payload file $(basename "$f") was not imported"
        done
      fi
      # a model already local (imported from the payload, or resumed)
      # serves without the network
      if ollama list 2>/dev/null | awk 'NR>1{print $1}' | grep -Fxq "$model"; then
        echo "model already local, skipping the network pull"
      else
        for _ in 1 2 3; do
          if ollama pull "$model"; then break; fi
          sleep 30
        done
      fi
      # digest check against the catalog. Warn-only here: first boot
      # must complete even if the upstream repo re-uploaded the file,
      # but the warning lands in the journal and on the console.
      vrc=0
      /usr/lib/llmd/llmd-model-verify "$model" || vrc=$?
      if [[ "$vrc" -eq 1 ]]; then
        echo "WARNING: $model does not match the catalog digest; verify it before trusting this system (sibilla model use re-checks)"
      fi
      ;;
    vllm)
      echo "LLMD_MODEL=$model" > /etc/llmd/vllm.env
      # the HF download happens at the first container start (persistent cache)
      ;;
  esac
fi

# 3. Gateway: render the Caddy config; the mode lives in gateway.conf
# (plain http by default, switch with sibilla-tls)
[[ -r /etc/llmd/gateway.conf ]] || printf 'MODE=http\n' > /etc/llmd/gateway.conf
/usr/lib/llmd/llmd-gateway-render

# 4. Services. The vllm unit is generated by Quadlet: it cannot be
# enabled with systemctl (boot activation comes from its [Install]
# section), so it is only started.
systemctl daemon-reload
case "$engine" in
  vllm) systemctl start vllm.service ;;
  *)    systemctl enable --now ollama.service ;;
esac
# access log directory: the caddy user only exists after its package
# is installed, so the ownership cannot be fixed in a deb
mkdir -p /var/log/caddy
if id caddy >/dev/null 2>&1; then
  chown caddy:caddy /var/log/caddy
fi
# caddy is already running with the stock config from the Ubuntu package,
# so enable --now would be a no-op: an explicit restart loads our gateway
# config and the API key environment
systemctl enable caddy.service
systemctl restart caddy.service

# Steps 5 and 6 are appliance behavior: they reconfigure the whole
# machine (firewall, package source) and only make sense on the ISO
# and cloud images, which set /etc/llmd/appliance. On an existing
# system set up with `sibilla setup` the marker is absent and we stay
# a good guest: no firewall takeover, no apt source flip.
if [[ -e /etc/llmd/appliance ]]; then
  # 5. SibillaOS apt source: shipped disabled because an unreachable
  # repository would break the installer's final apt-get update (the
  # repo goes live with the first tagged release). Enable it once it
  # actually answers.
  APT_SRC=/etc/apt/sources.list.d/sibillaos.sources
  if [[ -f "$APT_SRC" ]] && grep -q '^Enabled: no' "$APT_SRC"; then
    if curl -fsS -m 10 https://engineering87.github.io/sibillaos/apt/InRelease >/dev/null 2>&1; then
      sed -i 's/^Enabled: no/Enabled: yes/' "$APT_SRC"
      echo "SibillaOS apt repository enabled"
    else
      echo "SibillaOS apt repository not reachable yet, source left disabled"
    fi
  fi

  # 6. Firewall: default-closed, only SSH and the gateway port open.
  # Open WebUI's port 3000 stays closed until the admin opens it
  # deliberately (sibilla webui enable prints the command).
  if command -v ufw >/dev/null 2>&1; then
    ufw allow OpenSSH >/dev/null 2>&1 || ufw allow 22/tcp >/dev/null
    ufw allow 8080/tcp >/dev/null
    ufw --force enable
    echo "firewall enabled: only SSH and the gateway port are open"
  fi
fi

# the payload has served its purpose; leave the volume clean
if [[ -n "$AIRGAP_MNT" ]]; then
  umount "$AIRGAP_MNT" 2>/dev/null || true
  rmdir "$AIRGAP_MNT" 2>/dev/null || true
fi

# 7. Declared profile: the model was seeded before selection, now the
# rest of the declaration converges (tls, metrics, mcp, webui). Warn,
# do not fail: first boot must end in a serving machine even if one
# profile line cannot apply; sibilla apply re-runs idempotently.
if [[ -s /etc/llmd/profile && -x /usr/lib/llmd/sibilla-apply ]]; then
  /usr/lib/llmd/sibilla-apply /etc/llmd/profile \
    || echo "WARNING: profile did not fully apply; run: sudo sibilla apply"
fi

touch "$STATE"
echo "SibillaOS is ready: OpenAI-compatible API on :8080 (key in /etc/llmd/apikey)"
