#!/usr/bin/env bash
# sibilla: single entry point for SibillaOS administration.
# The sibilla-* commands keep working as aliases.
set -euo pipefail

usage() {
  cat <<USAGE
usage: sibilla COMMAND [ARGS]

  setup          turn this Ubuntu machine into an LLM appliance:
                 detect hardware, install the engine, serve the API
  status         health view: engine, served models, disk, GPU, gateway
  model ...      list, download, switch and remove models
  tls ...        switch the gateway between HTTP and HTTPS
  key ...        manage the gateway API keys (list, add, revoke, rotate)
  metrics ...    Prometheus endpoint on the gateway, on or off
  webui ...      enable or disable the Open WebUI chat interface
  connect        print client configuration for editors and agents
                 (--write places the Continue config, with backup)
  doctor         paste-ready diagnostic report, no secrets included
  remove         clean teardown: only what SibillaOS installed goes

Run a command without arguments for its own usage.
USAGE
  exit 1
}

cmd="${1:-}"
[[ $# -gt 0 ]] && shift
case "$cmd" in
  setup)   exec /usr/lib/llmd/sibilla-setup "$@" ;;
  status)  exec /usr/lib/llmd/sibilla-status "$@" ;;
  model)   exec sibilla-model "$@" ;;
  tls)     exec sibilla-tls "$@" ;;
  key)     exec sibilla-key "$@" ;;
  metrics) exec sibilla-metrics "$@" ;;
  webui)   exec sibilla-webui "$@" ;;
  connect) exec sibilla-connect "$@" ;;
  doctor)  exec /usr/lib/llmd/sibilla-doctor "$@" ;;
  remove)  exec /usr/lib/llmd/sibilla-remove "$@" ;;
  *)       usage ;;
esac
