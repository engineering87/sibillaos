#!/usr/bin/env bash
# sibilla-model: list, pick and switch the model served by SibillaOS.
set -euo pipefail

CATALOG=/usr/share/llmd/models.json
ENGINE=$(cat /etc/llmd/engine 2>/dev/null || echo ollama)
CURRENT=$(cat /etc/llmd/model 2>/dev/null || true)

usage() {
  cat <<EOF
usage: sibilla-model COMMAND

  status         show engine, current model and API endpoint
  list           curated models for this machine, plus llmfit picks
  use MODEL_ID   download MODEL_ID and make it the served model
  rm MODEL_ID    remove a downloaded model (refuses the served one)
  prune          remove every downloaded model except the served one
EOF
  exit 1
}

need_root() { [[ $EUID -eq 0 ]] || { echo "run as root (sudo)" >&2; exit 1; }; }

cmd_status() {
  echo "engine:  $ENGINE"
  echo "model:   ${CURRENT:-none selected}"
  echo "api:     http://$(hostname -I 2>/dev/null | awk '{print $1}'):8080 (key in /etc/llmd/apikey)"
}

cmd_list() {
  echo "curated models for engine '$ENGINE' (current: ${CURRENT:-none}):"
  jq -r --arg e "$ENGINE" \
    '.models[] | select(.engines[]? == $e) | "  " + .id + "  [" + .family + ", " + .license + "]"' \
    "$CATALOG"
  if command -v llmfit >/dev/null 2>&1; then
    echo
    echo "llmfit recommendations for this hardware:"
    llmfit recommend --json --limit 5 2>/dev/null \
      | jq -r '.. | objects | .model? // empty' 2>/dev/null | head -5 | sed 's/^/  /' \
      || echo "  (llmfit recommendation unavailable)"
  fi
}

cmd_use() {
  need_root
  local model="$1"
  # the ollama CLI panics without HOME when run over ssh/sudo
  export HOME="${HOME:-/root}"
  case "$ENGINE" in
    ollama)
      ollama pull "$model"
      ;;
    vllm)
      echo "LLMD_MODEL=$model" > /etc/llmd/vllm.env
      systemctl restart vllm.service
      ;;
  esac
  echo "$model" > /etc/llmd/model
  echo "now serving: $model"
}

cmd_rm() {
  need_root
  local model="$1"
  if [[ -n "$CURRENT" && "$model" == "$CURRENT" ]]; then
    echo "refusing to remove the served model; switch first with: sibilla model use ID" >&2
    exit 1
  fi
  # the ollama CLI panics without HOME when run over ssh/sudo
  export HOME="${HOME:-/root}"
  case "$ENGINE" in
    ollama)
      ollama rm "$model"
      ;;
    vllm)
      # vllm models live in the shared HF cache; the repo id maps to
      # a models--org--name directory inside hub/
      local dir="/var/lib/llmd/models/hf/hub/models--${model//\//--}"
      [[ -d "$dir" ]] || { echo "no local files for $model" >&2; exit 1; }
      rm -rf "$dir"
      ;;
  esac
  echo "removed: $model"
}

cmd_prune() {
  need_root
  export HOME="${HOME:-/root}"
  local removed=0
  case "$ENGINE" in
    ollama)
      while IFS= read -r m; do
        [[ -z "$m" || "$m" == "$CURRENT" ]] && continue
        ollama rm "$m" && removed=$((removed + 1))
      done < <(ollama list 2>/dev/null | tail -n +2 | awk '{print $1}')
      ;;
    vllm)
      local keep="models--${CURRENT//\//--}"
      local d
      for d in /var/lib/llmd/models/hf/hub/models--*; do
        [[ -e "$d" ]] || continue
        [[ "$(basename "$d")" == "$keep" ]] && continue
        rm -rf "$d"
        removed=$((removed + 1))
      done
      ;;
  esac
  echo "removed $removed model(s); kept: ${CURRENT:-none}"
  du -sh /var/lib/llmd/models 2>/dev/null || true
}

case "${1:-}" in
  status) cmd_status ;;
  list)   cmd_list ;;
  use)    [[ $# -ge 2 ]] || usage; cmd_use "$2" ;;
  rm)     [[ $# -ge 2 ]] || usage; cmd_rm "$2" ;;
  prune)  cmd_prune ;;
  *)      usage ;;
esac
