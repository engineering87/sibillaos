#!/usr/bin/env bash
# sibilla-connect: print ready-to-paste configuration for coding tools on
# your workstation, pointed at this SibillaOS machine. With --write the
# Continue and aider configurations are written in place (existing files
# backed up). The single-purpose outputs (--env, --mcp, --snippet) print
# only their payload, so they can be redirected into a file.
set -euo pipefail

usage() {
  cat <<USAGE
usage: sibilla connect              full connection kit for humans
       sibilla connect --write     also write ~/.continue/config.yaml
                                   and ~/.aider.conf.yml (with backups)
       sibilla connect --env       .env lines for any OpenAI SDK or
                                   framework (redirect into your .env)
       sibilla connect --mcp       the claude mcp add command for this
                                   machine, key filled in
       sibilla connect --snippet python|node
                                   SDK boilerplate, endpoint and key
                                   filled in
       sibilla connect --remote    a self-contained script for the
                                   developer workstation: run it there,
                                   it prompts for the key on stdin
                                   (never argv, never shell history)
                                   and writes Continue, aider and an
                                   optional project .env
USAGE
  exit 1
}

WRITE=0
OUTPUT=kit
SNIPPET_LANG=""
case "${1:-}" in
  --write)   WRITE=1 ;;
  --env)     OUTPUT="env" ;;
  --mcp)     OUTPUT=mcp ;;
  --remote)  OUTPUT=remote ;;
  --snippet)
    OUTPUT=snippet
    SNIPPET_LANG="${2:-}"
    [[ "$SNIPPET_LANG" == "python" || "$SNIPPET_LANG" == "node" ]] || usage
    ;;
  -h|--help) usage ;;
  "") ;;
  *) usage ;;
esac

[[ $EUID -eq 0 ]] || { echo "run as root (sudo): the API key lives in /etc/llmd/apikey" >&2; exit 1; }

MODE=http
TLS_HOSTNAME=""
# shellcheck disable=SC1091
[[ -r /etc/llmd/gateway.conf ]] && . /etc/llmd/gateway.conf

KEY=$(cat /etc/llmd/apikey 2>/dev/null || true)
MODEL=$(cat /etc/llmd/model 2>/dev/null || echo "default")
IP=$(hostname -I 2>/dev/null | awk '{print $1}')

CANOTE=0
case "$MODE" in
  internal) BASE="https://$TLS_HOSTNAME:8080/v1"; CANOTE=1 ;;
  acme)     BASE="https://$TLS_HOSTNAME/v1" ;;
  *)        BASE="http://$IP:8080/v1" ;;
esac

# single-purpose outputs: payload only, nothing else, so redirection
# into a config file yields a valid file
case "$OUTPUT" in
  remote)
    # A script for the developer workstation (Linux/macOS). Generated
    # in two parts: %q-quoted variable assignments (injection-safe),
    # then a fully literal body ('EOS'), so nothing expands here on
    # the server. The key deliberately never appears: the script
    # prompts for it on stdin at run time and refuses to write any
    # file until the gateway accepts it.
    printf '#!/usr/bin/env bash\nBASE=%q\nMODEL=%q\nCANOTE=%q\n' "$BASE" "$MODEL" "$CANOTE"
    cat <<'EOS'
set -euo pipefail
echo "SibillaOS workstation kit for $BASE (model: $MODEL)"
read -rs -p "Paste the API key (input stays hidden): " KEY; echo
[ -n "$KEY" ] || { echo "empty key, nothing written" >&2; exit 1; }
code=$(curl -s -o /dev/null -w '%{http_code}' -m 10 \
  -H "Authorization: Bearer $KEY" "$BASE/models" || true)
if [ "$code" != "200" ]; then
  echo "the gateway at $BASE did not accept the key (HTTP $code); nothing written" >&2
  [ "$CANOTE" = "1" ] && echo "note: this host uses a locally trusted CA (curl -k to test reachability)" >&2
  exit 1
fi
echo "authenticated: $BASE serves $MODEL"
cfg_dir="$HOME/.continue"; cfg="$cfg_dir/config.yaml"
mkdir -p "$cfg_dir"
if [ -f "$cfg" ] && [ ! -f "$cfg.pre-sibilla" ]; then
  cp -a "$cfg" "$cfg.pre-sibilla"; echo "existing Continue config backed up as config.yaml.pre-sibilla"
fi
cat > "$cfg" <<CFG
# written by the SibillaOS workstation kit
models:
  - name: SibillaOS
    provider: openai
    model: $MODEL
    apiBase: $BASE
    apiKey: $KEY
    roles:
      - chat
      - edit
CFG
chmod 600 "$cfg"
echo "wrote $cfg (VS Code and JetBrains via Continue)"
aider_cfg="$HOME/.aider.conf.yml"
if [ -f "$aider_cfg" ] && [ ! -f "$aider_cfg.pre-sibilla" ]; then
  cp -a "$aider_cfg" "$aider_cfg.pre-sibilla"; echo "existing aider config backed up"
fi
cat > "$aider_cfg" <<CFG
# written by the SibillaOS workstation kit
model: openai/$MODEL
openai-api-base: $BASE
openai-api-key: $KEY
CFG
chmod 600 "$aider_cfg"
echo "wrote $aider_cfg"
if [ -n "${1:-}" ]; then
  mkdir -p "$1"
  cat > "$1/.env" <<CFG
OPENAI_BASE_URL=$BASE
OPENAI_API_KEY=$KEY
OPENAI_MODEL=$MODEL
CFG
  chmod 600 "$1/.env"
  echo "wrote $1/.env (project scaffold for SDKs and frameworks)"
fi
if [ "$CANOTE" = "1" ]; then
  echo "note: the gateway uses a locally trusted CA; import its root"
  echo "certificate on this workstation or configure clients accordingly"
fi
echo "done. Reload your editor; aider and SDKs pick the files up as is."
EOS
    exit 0
    ;;
  env)
    cat <<ENV
# SibillaOS connection for OpenAI SDKs and frameworks (LangChain,
# LlamaIndex, plain clients); generated by sibilla connect --env
OPENAI_BASE_URL=$BASE
OPENAI_API_KEY=$KEY
OPENAI_MODEL=$MODEL
ENV
    exit 0
    ;;
  mcp)
    cat <<MCP
claude mcp add --transport http sibillaos \\
  ${BASE%/v1}/mcp \\
  --header "Authorization: Bearer $KEY"
MCP
    exit 0
    ;;
  snippet)
    if [[ "$SNIPPET_LANG" == "python" ]]; then
      cat <<SNIP
from openai import OpenAI

client = OpenAI(base_url="$BASE", api_key="$KEY")
reply = client.chat.completions.create(
    model="$MODEL",
    messages=[{"role": "user", "content": "hello"}],
)
print(reply.choices[0].message.content)
SNIP
    else
      cat <<SNIP
import OpenAI from "openai";

const client = new OpenAI({ baseURL: "$BASE", apiKey: "$KEY" });
const reply = await client.chat.completions.create({
  model: "$MODEL",
  messages: [{ role: "user", content: "hello" }],
});
console.log(reply.choices[0].message.content);
SNIP
    fi
    exit 0
    ;;
esac

cat <<KIT
SibillaOS connection kit
========================
endpoint:  $BASE
api key:   $KEY
model id:  $MODEL

VS Code and JetBrains (Continue, ~/.continue/config.yaml)
----------------------------------------------------------
models:
  - name: SibillaOS
    provider: openai
    model: $MODEL
    apiBase: $BASE
    apiKey: $KEY
    roles:
      - chat
      - edit

VS Code (Cline)
---------------
Settings -> API Provider: OpenAI Compatible
  Base URL:  $BASE
  API Key:   $KEY
  Model ID:  $MODEL

aider
-----
aider --openai-api-base $BASE --openai-api-key $KEY --model openai/$MODEL

Zed (settings.json)
-------------------
"language_models": { "openai": { "api_url": "$BASE" } }
(Zed asks for the key itself and stores it in its credential store;
paste the one above)

Any OpenAI-compatible client
----------------------------
export OPENAI_BASE_URL=$BASE
export OPENAI_API_KEY=$KEY

More formats: --env (frameworks), --mcp (Claude Code and MCP
agents), --snippet python|node (SDK boilerplate), --remote (a script
for your workstation: prompts for the key there, never in argv or
history). Cline keeps its settings inside VS Code state: paste the
values above by hand.
KIT

if [[ "$CANOTE" -eq 1 ]]; then
  cat <<'NOTE'

Note: the gateway uses a locally trusted CA. Import its certificate on
your workstation (on this machine:
/var/lib/caddy/.local/share/caddy/pki/authorities/local/root.crt) or
configure the client to skip TLS verification for this host.
NOTE
fi

# --write: place the Continue configuration for the invoking user
# (the one behind sudo), backing up whatever was there before
if [[ "$WRITE" -eq 1 ]]; then
  target_user="${SUDO_USER:-root}"
  target_home=$(getent passwd "$target_user" | cut -d: -f6)
  [[ -n "$target_home" ]] || { echo "cannot resolve home for $target_user" >&2; exit 1; }
  cfg_dir="$target_home/.continue"
  cfg="$cfg_dir/config.yaml"
  mkdir -p "$cfg_dir"
  if [[ -f "$cfg" && ! -f "$cfg.pre-sibilla" ]]; then
    cp -a "$cfg" "$cfg.pre-sibilla"
    echo
    echo "existing Continue config backed up as config.yaml.pre-sibilla"
  fi
  cat > "$cfg" <<CFG
# written by sibilla connect --write
models:
  - name: SibillaOS
    provider: openai
    model: $MODEL
    apiBase: $BASE
    apiKey: $KEY
    roles:
      - chat
      - edit
CFG
  chown -R "$target_user:" "$cfg_dir" 2>/dev/null || true
  chmod 600 "$cfg"
  echo
  echo "wrote $cfg for user $target_user (Continue picks it up on reload)"

  # aider reads a plain yaml in the home directory; same backup rule
  aider_cfg="$target_home/.aider.conf.yml"
  if [[ -f "$aider_cfg" && ! -f "$aider_cfg.pre-sibilla" ]]; then
    cp -a "$aider_cfg" "$aider_cfg.pre-sibilla"
    echo "existing aider config backed up as .aider.conf.yml.pre-sibilla"
  fi
  cat > "$aider_cfg" <<CFG
# written by sibilla connect --write
model: openai/$MODEL
openai-api-base: $BASE
openai-api-key: $KEY
CFG
  chown "$target_user:" "$aider_cfg" 2>/dev/null || true
  chmod 600 "$aider_cfg"
  echo "wrote $aider_cfg for user $target_user"
fi
