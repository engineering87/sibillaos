#!/usr/bin/env bash
# sibilla-connect: print ready-to-paste configuration for coding tools on
# your workstation, pointed at this SibillaOS machine. With --write the
# Continue and aider configurations are written in place (existing files
# backed up). The single-purpose outputs (--env, --mcp, --snippet) print
# only their payload, so they can be redirected into a file.
set -euo pipefail

usage() {
  cat <<USAGE
usage: sibilla connect              full connection kit for humans
       sibilla connect --write     also write ~/.continue/config.yaml
                                   and ~/.aider.conf.yml (with backups)
       sibilla connect --env       .env lines for any OpenAI SDK or
                                   framework (redirect into your .env)
       sibilla connect --mcp       the claude mcp add command for this
                                   machine, key filled in
       sibilla connect --snippet python|node
                                   SDK boilerplate, endpoint and key
                                   filled in
USAGE
  exit 1
}

WRITE=0
OUTPUT=kit
SNIPPET_LANG=""
case "${1:-}" in
  --write)   WRITE=1 ;;
  --env)     OUTPUT="env" ;;
  --mcp)     OUTPUT=mcp ;;
  --snippet)
    OUTPUT=snippet
    SNIPPET_LANG="${2:-}"
    [[ "$SNIPPET_LANG" == "python" || "$SNIPPET_LANG" == "node" ]] || usage
    ;;
  -h|--help) usage ;;
  "") ;;
  *) usage ;;
esac

[[ $EUID -eq 0 ]] || { echo "run as root (sudo): the API key lives in /etc/llmd/apikey" >&2; exit 1; }

MODE=http
TLS_HOSTNAME=""
# shellcheck disable=SC1091
[[ -r /etc/llmd/gateway.conf ]] && . /etc/llmd/gateway.conf

KEY=$(cat /etc/llmd/apikey 2>/dev/null || true)
MODEL=$(cat /etc/llmd/model 2>/dev/null || echo "default")
IP=$(hostname -I 2>/dev/null | awk '{print $1}')

CANOTE=0
case "$MODE" in
  internal) BASE="https://$TLS_HOSTNAME:8080/v1"; CANOTE=1 ;;
  acme)     BASE="https://$TLS_HOSTNAME/v1" ;;
  *)        BASE="http://$IP:8080/v1" ;;
esac

# single-purpose outputs: payload only, nothing else, so redirection
# into a config file yields a valid file
case "$OUTPUT" in
  env)
    cat <<ENV
# SibillaOS connection for OpenAI SDKs and frameworks (LangChain,
# LlamaIndex, plain clients); generated by sibilla connect --env
OPENAI_BASE_URL=$BASE
OPENAI_API_KEY=$KEY
OPENAI_MODEL=$MODEL
ENV
    exit 0
    ;;
  mcp)
    cat <<MCP
claude mcp add --transport http sibillaos \\
  ${BASE%/v1}/mcp \\
  --header "Authorization: Bearer $KEY"
MCP
    exit 0
    ;;
  snippet)
    if [[ "$SNIPPET_LANG" == "python" ]]; then
      cat <<SNIP
from openai import OpenAI

client = OpenAI(base_url="$BASE", api_key="$KEY")
reply = client.chat.completions.create(
    model="$MODEL",
    messages=[{"role": "user", "content": "hello"}],
)
print(reply.choices[0].message.content)
SNIP
    else
      cat <<SNIP
import OpenAI from "openai";

const client = new OpenAI({ baseURL: "$BASE", apiKey: "$KEY" });
const reply = await client.chat.completions.create({
  model: "$MODEL",
  messages: [{ role: "user", content: "hello" }],
});
console.log(reply.choices[0].message.content);
SNIP
    fi
    exit 0
    ;;
esac

cat <<KIT
SibillaOS connection kit
========================
endpoint:  $BASE
api key:   $KEY
model id:  $MODEL

VS Code and JetBrains (Continue, ~/.continue/config.yaml)
----------------------------------------------------------
models:
  - name: SibillaOS
    provider: openai
    model: $MODEL
    apiBase: $BASE
    apiKey: $KEY
    roles:
      - chat
      - edit

VS Code (Cline)
---------------
Settings -> API Provider: OpenAI Compatible
  Base URL:  $BASE
  API Key:   $KEY
  Model ID:  $MODEL

aider
-----
aider --openai-api-base $BASE --openai-api-key $KEY --model openai/$MODEL

Any OpenAI-compatible client
----------------------------
export OPENAI_BASE_URL=$BASE
export OPENAI_API_KEY=$KEY

More formats: --env (frameworks), --mcp (Claude Code and MCP
agents), --snippet python|node (SDK boilerplate). Cline keeps its
settings inside VS Code state: paste the values above by hand.
KIT

if [[ "$CANOTE" -eq 1 ]]; then
  cat <<'NOTE'

Note: the gateway uses a locally trusted CA. Import its certificate on
your workstation (on this machine:
/var/lib/caddy/.local/share/caddy/pki/authorities/local/root.crt) or
configure the client to skip TLS verification for this host.
NOTE
fi

# --write: place the Continue configuration for the invoking user
# (the one behind sudo), backing up whatever was there before
if [[ "$WRITE" -eq 1 ]]; then
  target_user="${SUDO_USER:-root}"
  target_home=$(getent passwd "$target_user" | cut -d: -f6)
  [[ -n "$target_home" ]] || { echo "cannot resolve home for $target_user" >&2; exit 1; }
  cfg_dir="$target_home/.continue"
  cfg="$cfg_dir/config.yaml"
  mkdir -p "$cfg_dir"
  if [[ -f "$cfg" && ! -f "$cfg.pre-sibilla" ]]; then
    cp -a "$cfg" "$cfg.pre-sibilla"
    echo
    echo "existing Continue config backed up as config.yaml.pre-sibilla"
  fi
  cat > "$cfg" <<CFG
# written by sibilla connect --write
models:
  - name: SibillaOS
    provider: openai
    model: $MODEL
    apiBase: $BASE
    apiKey: $KEY
    roles:
      - chat
      - edit
CFG
  chown -R "$target_user:" "$cfg_dir" 2>/dev/null || true
  chmod 600 "$cfg"
  echo
  echo "wrote $cfg for user $target_user (Continue picks it up on reload)"

  # aider reads a plain yaml in the home directory; same backup rule
  aider_cfg="$target_home/.aider.conf.yml"
  if [[ -f "$aider_cfg" && ! -f "$aider_cfg.pre-sibilla" ]]; then
    cp -a "$aider_cfg" "$aider_cfg.pre-sibilla"
    echo "existing aider config backed up as .aider.conf.yml.pre-sibilla"
  fi
  cat > "$aider_cfg" <<CFG
# written by sibilla connect --write
model: openai/$MODEL
openai-api-base: $BASE
openai-api-key: $KEY
CFG
  chown "$target_user:" "$aider_cfg" 2>/dev/null || true
  chmod 600 "$aider_cfg"
  echo "wrote $aider_cfg for user $target_user"
fi
