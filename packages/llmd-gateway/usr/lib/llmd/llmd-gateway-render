#!/usr/bin/env bash
# llmd-gateway-render: writes /etc/caddy/Caddyfile from /etc/llmd/gateway.conf
# Modes: http (default, port 8080), internal (HTTPS on 8080 with Caddy's
# local CA for a given hostname), acme (public HTTPS on 443 with Let's
# Encrypt; requires a reachable hostname and open ports 80/443).
# METRICS=on adds an authenticated Prometheus endpoint at /metrics/gateway.
# The MCP endpoint (sibilla mcp) lives in its own state file rather than
# in gateway.conf: the sibilla-tls and sibilla-metrics conf writers only
# preserve the keys they know about.
set -euo pipefail

# paths are overridable so the CI lint job can render and validate
# the configs on a plain runner
CONF="${LLMD_GATEWAY_CONF:-/etc/llmd/gateway.conf}"
CADDYFILE="${LLMD_CADDYFILE:-/etc/caddy/Caddyfile}"
ENGINE_FILE="${LLMD_ENGINE_FILE:-/etc/llmd/engine}"
ACCESS_LOG="${LLMD_ACCESS_LOG:-/var/log/caddy/sibilla-access.log}"
MCP_FILE="${LLMD_MCP_FILE:-/etc/llmd/mcp}"
MODE=http
TLS_HOSTNAME=""
ACME_EMAIL=""
METRICS=off
# shellcheck disable=SC1090
[[ -r "$CONF" ]] && . "$CONF"
mcp=$(cat "$MCP_FILE" 2>/dev/null || echo off)

engine=$(cat "$ENGINE_FILE" 2>/dev/null || echo ollama)
case "$engine" in
  vllm) upstream="127.0.0.1:8000" ;;
  *)    upstream="127.0.0.1:11434" ;;
esac

# Global options block (a Caddyfile allows exactly one, so email and
# metrics are merged here). HTTP metrics instrumentation is opt-in
# per server since Caddy 2.6 (serverOpts.Metrics in the source): the
# "servers { metrics }" option is what makes the caddy_http_* series
# exist at all.
global_block() {
  local acme_email="$1"
  if [[ "$METRICS" != "on" && -z "$acme_email" ]]; then
    return 0
  fi
  echo "{"
  if [[ -n "$acme_email" ]]; then
    echo "	email $acme_email"
  fi
  if [[ "$METRICS" == "on" ]]; then
    echo "	servers {"
    echo "		metrics"
    echo "	}"
  fi
  echo "}"
}

# The site body is wrapped in a route block because Caddy's default
# directive order runs handlers like metrics BEFORE respond: without
# route, /metrics/gateway would be served to unauthenticated clients.
# route preserves the written order, so the 401 always comes first.
#
# Authentication accepts any configured key: llmd-keys-render builds
# a regex alternation from /etc/llmd/apikey plus /etc/llmd/apikeys.d
# and hands it to Caddy through the LLMD_KEYS_ALT environment
# variable (keys are generated alphanumeric, so they are regex-safe).
#
# The proxied Host header is rewritten to the upstream address: ollama
# guards against DNS rebinding (allowedHostsMiddleware in its
# server/routes.go) and drops any non-local Host on a loopback
# listener with an empty 403, which would break every authenticated
# request as soon as the gateway serves a hostname.
site_body() {
  cat <<BLOCK
	log {
		output file $ACCESS_LOG
	}
BLOCK
  cat <<'BLOCK'
	# API keys: default in /etc/llmd/apikey, extra keys in
	# /etc/llmd/apikeys.d, managed by sibilla key
	@unauthorized not header_regexp Authorization "^Bearer ({$LLMD_KEYS_ALT})$"
BLOCK
  if [[ "$METRICS" == "on" ]]; then
    cat <<'BLOCK'
	@gwmetrics path /metrics/gateway
BLOCK
  fi
  echo "	route {"
  echo "		respond @unauthorized 401"
  if [[ "$METRICS" == "on" ]]; then
    echo "		metrics @gwmetrics"
  fi
  if [[ "$mcp" == "on" ]]; then
    # the MCP server (llmd-mcp.service) on loopback; it never sees
    # the keys, the 401 above is its whole authentication story
    echo "		reverse_proxy /mcp 127.0.0.1:8765"
  fi
  cat <<BLOCK
		reverse_proxy $upstream {
			header_up Host {upstream_hostport}
		}
	}
BLOCK
}

case "$MODE" in
  internal)
    [[ -n "$TLS_HOSTNAME" ]] || { echo "internal mode needs TLS_HOSTNAME" >&2; exit 1; }
    {
      global_block ""
      echo "https://$TLS_HOSTNAME:8080 {"
      echo "	tls internal"
      site_body
      echo "}"
    } > "$CADDYFILE"
    ;;
  acme)
    [[ -n "$TLS_HOSTNAME" && -n "$ACME_EMAIL" ]] || { echo "acme mode needs TLS_HOSTNAME and ACME_EMAIL" >&2; exit 1; }
    {
      global_block "$ACME_EMAIL"
      echo "$TLS_HOSTNAME {"
      site_body
      echo "}"
    } > "$CADDYFILE"
    ;;
  *)
    {
      global_block ""
      echo ":8080 {"
      site_body
      echo "}"
    } > "$CADDYFILE"
    ;;
esac
echo "gateway config rendered: mode=$MODE upstream=$upstream metrics=$METRICS mcp=$mcp"
