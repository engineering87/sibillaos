#cloud-config
# SibillaOS autoinstall (Subiquity / NoCloud), applied on top of the
# official Ubuntu live-server installer.
# PoC: non-interactive install; engine and model chosen by llmd-hw + llmfit.
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  identity:
    hostname: sibillaos
    username: sibilla
    # password "sibilla": only used by fully unattended CI installs;
    # release builds make the identity screen interactive (see build.sh)
    password: "$6$rounds=4096$sibillaPoC$Xyzu7IZ4lUow9B0qOngdavYLr.qSwgUBGWdTMmDLOZ14andyQ/qZdzb01wKYiVnzVtn8winGUNAi2Z2g5YQhP0"
  ssh:
    install-server: true
    allow-pw: true
  storage:
    layout:
      name: lvm
  packages:
    - curl
    - jq
    - pciutils
    - caddy
    - ufw
    - unattended-upgrades
  drivers:
    # Install NVIDIA drivers from the Ubuntu restricted component when detected
    install: true
  late-commands:
    # 1. Copy the SibillaOS payload from the ISO into the target
    - cp -r /cdrom/sibilla /target/opt/sibilla
    # 2. Install the llmd packages (the model catalog ships inside llmd-hw)
    - curtin in-target -- bash -c 'dpkg -i /opt/sibilla/debs/*.deb || apt-get -f install -y'
    # 3. Inference engine, PINNED version for reproducible builds (bump
    #    deliberately; the CI install test validates it). llmfit ships as
    #    a deb in the ISO payload since v0.2.
    - curtin in-target -- bash -c 'curl -fsSL https://ollama.com/install.sh | OLLAMA_VERSION=0.31.1 sh'
    # 4. Hardware detection and default model pick (non-fatal: firstboot
    #    still brings the gateway up without a preselected model)
    - curtin in-target -- /usr/lib/llmd/llmd-hw-detect --write /etc/llmd/engine
    - curtin in-target -- bash -c '/usr/lib/llmd/llmd-model-select --auto --catalog /usr/share/llmd/models.json --out /etc/llmd/model || true'
    #    CI only: a /sibilla/ci-model file on the ISO overrides the pick
    #    with a small model to keep the pipeline fast (absent in releases)
    - curtin in-target -- bash -c 'test -f /opt/sibilla/ci-model && install -m644 /opt/sibilla/ci-model /etc/llmd/model || true'
    - curtin in-target -- systemctl enable llmd-firstboot.service
    # 5. Branding and serial console on the installed system
    - curtin in-target -- bash -c 'install -D -m644 /opt/sibilla/wallpaper.png /usr/share/backgrounds/sibillaos/wallpaper.png || true'
    - curtin in-target -- sed -i 's/GRUB_CMDLINE_LINUX_DEFAULT="/&console=tty0 console=ttyS0,115200n8 /' /etc/default/grub
    - curtin in-target -- update-grub
  user-data:
    disable_root: true
