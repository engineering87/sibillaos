#cloud-config
# SibillaOS autoinstall (Subiquity / NoCloud), applied on top of the
# official Ubuntu live-server installer.
# PoC: non-interactive install; engine and model chosen by llmd-hw + llmfit.
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  identity:
    hostname: sibillaos
    username: sibilla
    # password "sibilla": only used by fully unattended CI installs;
    # release builds make the identity screen interactive (see build.sh)
    password: "$6$rounds=4096$sibillaPoC$Xyzu7IZ4lUow9B0qOngdavYLr.qSwgUBGWdTMmDLOZ14andyQ/qZdzb01wKYiVnzVtn8winGUNAi2Z2g5YQhP0"
  ssh:
    install-server: true
    allow-pw: true
  storage:
    layout:
      name: lvm
  apt:
    # pin the primary mirror and disable the geoip redirect: the
    # geo CNAME (us.archive & co.) adds a resolution and a mirror
    # that vary per runner, and the installer's final apt-get update
    # is fatal when either misbehaves
    geoip: false
    primary:
      - arches: [amd64]
        uri: http://archive.ubuntu.com/ubuntu
      - arches: [default]
        uri: http://ports.ubuntu.com/ubuntu-ports
    # Translation files are description localization with no function
    # on a server, yet a mid-sync mirror serving a stale one fails the
    # whole apt-get update (seen for 11+ hours on noble-security);
    # skip them and retry transient fetch errors
    conf: |
      Acquire::Languages "none";
      Acquire::Retries "3";
  packages:
    - curl
    - jq
    - pciutils
    - caddy
    - ufw
    - unattended-upgrades
  drivers:
    # Install NVIDIA drivers from the Ubuntu restricted component when detected
    install: true
  error-commands:
    # on install failure, surface the real error on the serial console
    # (the subiquity summary only reports exit codes) and power off so
    # the CI job fails fast instead of sitting until its timeout
    - bash -c 'echo "=== SIBILLA INSTALL FAILED, diagnostics ===" > /dev/console'
    - bash -c 'ls -la /target/etc/apt/sources.list.d/ > /dev/console 2>&1 || true'
    - bash -c 'cat /target/etc/apt/sources.list.d/*.sources > /dev/console 2>&1 || true'
    # DNS state of the LIVE environment, to tell infrastructure
    # trouble apart from target-only misconfiguration
    - bash -c 'getent hosts archive.ubuntu.com > /dev/console 2>&1 || echo "live env cannot resolve archive.ubuntu.com" > /dev/console'
    # faithful reproduction of the failing step: /run bind-mounted so
    # the target resolv.conf stub actually points at the live resolver
    - bash -c 'mount --bind /run /target/run 2>/dev/null || true; chroot /target apt-get update 2>&1 | tail -60 > /dev/console; umount /target/run 2>/dev/null || true'
    - bash -c 'echo "=== end diagnostics ===" > /dev/console'
    - poweroff
  late-commands:
    # 1. Copy the SibillaOS payload from the ISO into the target
    - cp -r /cdrom/sibilla /target/opt/sibilla
    # 2. Install the llmd packages (the model catalog ships inside llmd-hw)
    - curtin in-target -- bash -c 'dpkg -i /opt/sibilla/debs/*.deb || apt-get -f install -y'
    # 3. Inference engine, PINNED version for reproducible builds (bump
    #    deliberately; the CI install test validates it). llmfit ships as
    #    a deb in the ISO payload since v0.2.
    - curtin in-target -- bash -c 'ok=0; for i in 1 2 3; do curl -fsSL https://ollama.com/install.sh | OLLAMA_VERSION=0.31.1 sh && { ok=1; break; }; echo "ollama install failed, retrying in 15s"; sleep 15; done; [ "$ok" -eq 1 ]'
    # 4. Hardware detection and default model pick (non-fatal: firstboot
    #    still brings the gateway up without a preselected model)
    - curtin in-target -- /usr/lib/llmd/llmd-hw-detect --write /etc/llmd/engine
    - curtin in-target -- bash -c '/usr/lib/llmd/llmd-model-select --auto --catalog /usr/share/llmd/models.json --out /etc/llmd/model || true'
    #    CI only: a /sibilla/ci-model file on the ISO overrides the pick
    #    with a small model to keep the pipeline fast (absent in releases)
    - curtin in-target -- bash -c 'test -f /opt/sibilla/ci-model && install -m644 /opt/sibilla/ci-model /etc/llmd/model || true'
    #    appliance marker: firstboot manages firewall and the apt
    #    source only on the images, not on `sibilla setup` installs
    - curtin in-target -- install -D -m644 /dev/null /etc/llmd/appliance
    - curtin in-target -- systemctl enable llmd-firstboot.service
    # 5. Branding and serial console on the installed system
    - curtin in-target -- bash -c 'install -D -m644 /opt/sibilla/wallpaper.png /usr/share/backgrounds/sibillaos/wallpaper.png || true'
    - curtin in-target -- sed -i 's/GRUB_CMDLINE_LINUX_DEFAULT="/&console=tty0 console=ttyS0,115200n8 /' /etc/default/grub
    - curtin in-target -- update-grub
  user-data:
    disable_root: true
